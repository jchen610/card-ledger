# CardLedger Environment Variables
# Place this file at: cardledger/.env

# ── Storage mode ───────────────────────────────────────────────────────────────
# true  = use local ./uploads folder (default, no AWS needed)
# false = require S3 — server will refuse to start if S3 is not configured
USE_LOCAL_STORAGE=false

# ── AWS S3 (required when USE_LOCAL_STORAGE=false) ─────────────────────────────
S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001